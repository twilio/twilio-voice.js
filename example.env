# This env file is only needed for running integration tests
# Make a copy of this file with the name .env and populate the file with your environment variables

# Twilio account sid
ACCOUNT_SID=xxxxxxxxxxxxxxxx

# Twilio auth token
AUTH_TOKEN=xxxxxxxxxxxxxxxx

# Twilio API secret
API_KEY_SECRET=xxxxxxxxxxxxxxxx

# Twilio API key
API_KEY_SID=xxxxxxxxxxxxxxxx

# "Integration Tests" TwiML App
APPLICATION_SID=xxxxxxxxxxxxxxxx

# "STIR/SHAKEN" TwiML App
APPLICATION_SID_STIR=xxxxxxxxxxxxxxxx

# Caller ID
CALLER_ID=xxxxxxxxxxxxxxxx

# SIP signaling — only required for SIP-over-WebSocket e2e tests

# SIP WebSocket transport URL
SIP_SERVER=xxxxxxxxxxxxxxxx

# SIP identity URI (e.g. sip:user@host.sip.dev.twilio.com)
SIP_URI=xxxxxxxxxxxxxxxx

# SIP digest auth username
SIP_USERNAME=xxxxxxxxxxxxxxxx

# SIP digest auth password
SIP_PASSWORD=xxxxxxxxxxxxxxxx

# Optional SIP region hint (e.g. ashburn)
SIP_REGION=xxxxxxxxxxxxxxxx
